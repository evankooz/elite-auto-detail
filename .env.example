# ═══════════════════════════════════════════════════════════════
# DETAILING SAAS — ENVIRONMENT VARIABLES
# Copy to .env.local and fill in your values.
# Set these same variables in Vercel project settings.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://eliteautoandhomedetail.com

# ── Supabase ──────────────────────────────────────────────────────
# Find in: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Twilio (SMS) ──────────────────────────────────────────────────
# Sign up at twilio.com — start with free trial
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ── Resend (Email) ────────────────────────────────────────────────
# Sign up at resend.com — 3,000 free emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Business owner notification targets ───────────────────────────
OWNER_PHONE=+15559876543
OWNER_EMAIL=owner@eliteautoandhomedetail.com

# ── Admin dashboard ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SECRET=your-very-secret-admin-key-here

# ── Vercel Cron (reminders) ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must match the secret in vercel.json cron path
CRON_SECRET=your-cron-secret-here
